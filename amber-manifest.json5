{
  manifest_version: "0.1.1",

  // Конфигурация: ТОЛЬКО Mistral, OpenRouter не требуется
  config_schema: {
    type: "object",
    properties: {
      // Обязательный ключ
      mistral_api_key: { type: "string", secret: true },
      
      // Опционально: модель (по умолчанию — small для экономии)
      mistral_model: { 
        type: "string", 
        default: "mistral-small-latest" 
      },
      
      // Пути для памяти и логов (опционально)
      agent_memory_dir: { type: "string", default: "./memory" },
      agent_logs_dir: { type: "string", default: "./logs" },
    },
    // Требуем только API-ключ
    required: ["mistral_api_key"],
    additionalProperties: false,
  },

  // Внешние сервисы (опционально)
  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  // Runtime-конфигурация
  program: {
    image: "ghcr.io/mrpetrakova2000/purple_agent_aith:latest",
    
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      // Фиксируем провайдера на Mistral
      LLM_PROVIDER: "mistral",
      
      MISTRAL_API_KEY: "${config.mistral_api_key}",
      MISTRAL_MODEL: "${config.mistral_model}",
      
      AGENT_MEMORY_DIR: "${config.agent_memory_dir}",
      AGENT_LOGS_DIR: "${config.agent_logs_dir}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}